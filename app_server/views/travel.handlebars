<h1>{{title}}</h1>

<div class="trip-list">
  {{#each trips}}
    <div class="trip-card">
      <h2>{{name}}</h2>
      <p><strong>Location:</strong> {{location}}</p>
      <p><strong>Price:</strong> {{price}}</p>
      <p>{{description}}</p>
      {{#if image}}
        <img src="{{image}}" alt="{{name}}" style="width:200px;">
      {{/if}}
    </div>
    <hr>
  {{/each}}
</div>