<!DOCTYPE html>
<html>
<head>
  <title>{{title}}</title>
  <link rel="stylesheet" href="/stylesheets/style.css">
</head>
<body>

<header>
  <h1>Travlr Getaways</h1>
  <nav>
    <a href="/">Home</a>
    <a href="/about">About</a>
    <a href="/travel">Travel</a>
  </nav>
</header>

<main>
  <h1>{{title}}</h1>

  <div class="trip-list">
    {{#each trips}}
      <div class="trip-card">
        <h2>{{name}}</h2>
        <p><strong>Length:</strong> {{length}}</p>
        <p><strong>Start:</strong> {{start}}</p>
        <p><strong>Resort:</strong> {{resort}}</p>
        <p><strong>Price:</strong> ${{perPerson}}</p>
        <p>{{description}}</p>
      </div>
      <hr>
    {{/each}}
  </div>
</main>

<footer>
  <p>© Travlr Getaways</p>
</footer>

</body>
</html>